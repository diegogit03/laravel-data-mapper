{
    "name": "diego/eloquent-data-mapper",
    "description": "Um data mapper para o eloquent",
    "type": "library",
    "version": "0.0.1",
    "license": "MIT",
    "scripts": {
        "stan": "./vendor/bin/phpstan analyse",
        "format": "./vendor/bin/pint -p",
        "test": "./vendor/bin/pest -p"
    },
    "autoload": {
        "psr-4": {
            "Diego\\EloquentDataMapper\\": "src/",
            "Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Diego",
            "email": "dhom91718@gmail.com"
        }
    ],
    "minimum-stability": "stable",
    "require-dev": {
        "phpstan/phpstan": "^2.2",
        "laravel/pint": "^1.29",
        "pestphp/pest": "^4.7"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
